# Root stress-test configuration. Copy to ../.env or create .env at repo root.
# Example: nano .env

# The maximum concurrent users discovered from the stress test.
# Load, spike, and soak tests derive their targets from this value.
MAX_USERS=100

# Resource monitor cadence.
# Live terminal metrics show total VM usage, including k6.
# Saved CSV and final summaries remain Docker-only app usage.
METRICS_SAMPLE_INTERVAL_SECONDS=1
METRICS_PRINT_INTERVAL_SECONDS=5

# Optional: override k6 binary path if installed somewhere else.
K6_BIN=k6
